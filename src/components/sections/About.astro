---
import Section from "../Section.astro";
import AboutIcon from "@/icons/AboutIcon.astro";

import { basics } from "@cv";
const { summary } = basics;
---

<Section title="About">
  <div class="icon-container">
    <AboutIcon />
  </div>
  <p class="summary">{summary}</p>
</Section>

<style>
  .summary {
    white-space: pre-line;
  }
</style>