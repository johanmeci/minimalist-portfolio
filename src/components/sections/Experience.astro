---
import Section from "../Section.astro";
import ExperienceIcon from "@/icons/ExperienceIcon.astro";

import { work } from "@cv";
---

<Section title="Experience">
  <div class="icon-container">
    <ExperienceIcon />
  </div>
  <ul>
    {
      (work || []).map(({ name, startDate, endDate, position, summary }) => {
        const startYear = startDate ? new Date(startDate).getFullYear() : "N/A";
        const endYear = endDate ? new Date(endDate).getFullYear() : "Present";
        const years = `${startYear} - ${endYear}`;

        return (
          <li>
            <article>
              <header>
                <div>
                  <h3>{name}</h3>
                  <p>{position}</p>
                </div>
                <time>{years}</time>
              </header>

              <footer>
                <p>{summary}</p>
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    li {
      border: 1px solid var(--border-color);
      padding: 1rem;
      border-radius: 5px;
      background-color: #ffffff;
    }
  }

  :global(.dark) li {
    background-color: var(--bg-primary);
  }

  article h3 {
    font-size: 1.3rem;
    margin-bottom: 0.3rem;
    font-weight: 700;
    color: #111;
  }

  :global(.dark) article h3 {
    color: #f3f3f3;
  }

  article h4 {
    color: #222;
    font-weight: 400;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.8rem;
  }

  footer p {
    white-space: pre-line;
  }

  time {
    font-size: 0.85rem;
    color: #555;
  }
</style>
