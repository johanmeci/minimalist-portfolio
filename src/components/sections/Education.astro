---
import Section from "../Section.astro";
import EducationIcon from "@/icons/EducationIcon.astro";

import { education } from "@cv";
---

<Section title="Education">
  <div class="icon-container">
    <EducationIcon />
  </div>
  <ul>
    {
      (education || [])
        .sort((a, b) => {
          const aTime = a.endDate
            ? new Date(a.endDate).getTime()
            : new Date().getTime();
          const bTime = b.endDate
            ? new Date(b.endDate).getTime()
            : new Date().getTime();
          return bTime - aTime;
        })
        .map(({ institution, startDate, endDate, area }) => {
          const startYear = startDate
            ? new Date(startDate).getFullYear()
            : "N/A";
          const endYear = endDate ? new Date(endDate).getFullYear() : "Actual";
          const years =
            startYear === endYear ? startYear : `${startYear} - ${endYear}`;

          return (
            <li>
              <article>
                <header>
                  <div>
                    <h3>{institution}</h3>
                  </div>
                  <time>{years}</time>
                </header>
                <footer>
                  <p>{area}</p>
                </footer>
              </article>
            </li>
          );
        })
    }
  </ul>
</Section>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  article h3 {
    font-weight: 700;
    color: #111;
  }

  :global(.dark) article h3 {
    color: #e3d3d3;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
  }

  time {
    color: #555;
    font-size: 0.85rem;
    min-width: 102px;
    text-align: right;
    padding-right: 0.5rem;
  }

  @media (width <= 700px) {
    time {
      text-align: right;
    }
  }
</style>
